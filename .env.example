# =====================================================================
# Daphne's Root - Environment Variables Configuration
# =====================================================================
# 
# Copy this file to .env.local for local development
# For Vercel, set these variables in the Project Settings dashboard
#
# =====================================================================

# ===== REQUIRED Environment Variables =====

# Node environment (development, production, test)
# For Vercel: Always set to "production"
NODE_ENV=production

# Database connection string (PostgreSQL)
# Format: postgresql://username:password@host:port/database
# 
# Recommended providers:
# - Railway: https://railway.app (has free tier)
# - Supabase: https://supabase.com (PostgreSQL DBaaS)
# - AWS RDS: https://aws.amazon.com/rds (production-grade)
# - DigitalOcean: https://digitalocean.com (managed databases)
#
# For Vercel: Set this in Project Settings -> Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/daphnes_root

# ===== Optional Environment Variables =====

# API Port (automatically set by Vercel, only needed for local dev)
PORT=3000

# Log level (log, debug, trace, info, warn, error)
LOG_LEVEL=info

# Enable detailed error messages in responses (NOT for production)
DEBUG=false

# CORS origin - restrict which origins can access the API
# For Vercel: Can be a specific domain or "*" for development
CORS_ORIGIN=*

# ===== Only for Local Development =====
# These are NOT needed on Vercel (Vercel handles them automatically)

# TypeScript configuration
TS_NODE_PROJECT=./api/tsconfig.json
TS_NODE_LOG_ERROR=true

# =====================================================================
# Setup Instructions for Vercel
# =====================================================================
#
# 1. Go to your Vercel dashboard
# 2. Select your project
# 3. Click "Settings" → "Environment Variables"
# 4. Add each variable from the "REQUIRED" section above
# 5. Redeploy the project
#
# =====================================================================

